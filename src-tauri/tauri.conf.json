{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InterlinedList Offline",
  "version": "0.1.0",
  "identifier": "com.interlinedlist.offline",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "InterlinedList Offline",
        "width": 1040,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Mirror web pages to a local folder for offline reading.",
    "longDescription": "InterlinedList Offline is a free, cross-platform desktop app that mirrors a single web page or an entire website to a local folder so you can read it offline. Safe, polite defaults; honest static mirrors; your captures never leave your device.",
    "copyright": "Copyright © 2026 InterlinedList",
    "publisher": "InterlinedList",
    "homepage": "https://interlinedlist.com",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/CompositeCode/tertiary-offline-web/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY2MUQ4Q0JBNDMwOEEyRDEKUldUUm9naER1b3dkWm9ack8zZGZYbGRtaEliVVR5eUk4TVczZ2xxdlRJNTE5OXNMNUJWUWozRU4K",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
