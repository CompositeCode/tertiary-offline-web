{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InterlinedList Offline",
  "version": "0.0.1",
  "identifier": "com.interlinedlist.offline",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "InterlinedList Offline",
        "width": 1040,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
